cat > postman/incident-ddr-collection.json << 'EOF'
{
  "info": {
    "name": "Incident DDR Automation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Pull Chats",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_time\": \"2026-02-05T09:00:00\",\n  \"end_time\": \"2026-02-05T09:30:00\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/chats/pull",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["chats", "pull"]
        }
      }
    },
    {
      "name": "Extract Timeline",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": []\n}"
        },
        "url": {
          "raw": "http://localhost:8000/timeline/extract",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["timeline", "extract"]
        }
      }
    },
    {
      "name": "Generate DDR Prompts",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"timeline\": []\n}"
        },
        "url": {
          "raw": "http://localhost:8000/prompts",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["prompts"]
        }
      }
    }
  ]
}
EOF