{
  "info": {
    "name": "Incident DDR API",
    "_postman_id": "incident-ddr-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('ENV GUARD – baseUrl is defined', function () {",
              "  const baseUrl = pm.variables.get('baseUrl');",
              "  pm.expect(baseUrl, 'baseUrl must be set').to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Health response is OK', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    }
  ]
}