[MASTER]
ignore=venv,__pycache__,.pytest_cache

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    line-too-long,
    trailing-newlines,
    missing-final-newline,
    too-few-public-methods,
    too-many-branches,
    too-many-positional-arguments,
    invalid-name,
    superfluous-parens,
    too-many-arguments,
    too-many-lines


[FORMAT]
max-line-length=140

[BASIC]
good-names=id,_,pk

# Allow API contract names (e.g. FastAPI path params)
argument-rgx=[a-z_][a-z0-9_]{0,30}$|incidentId

[IMPORTS]
known-third-party=fastapi,pydantic

[REPORTS]
reports=no
score=yes