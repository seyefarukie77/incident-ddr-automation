[MASTER]
ignore=venv,__pycache__,.pytest_cache,tests
persistent=no

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    too-many-branches,
    too-many-positional-arguments,
    too-many-arguments,
    too-many-lines,
    invalid-name,
    superfluous-parens,
    line-too-long

[FORMAT]
max-line-length=140

[DESIGN]
max-module-lines=1200

[BASIC]
good-names=id,_,pk

# Allow API contract names (e.g. FastAPI path params)
argument-rgx=[a-z_][a-z0-9_]{0,30}$|incidentId

[IMPORTS]
known-third-party=fastapi,pydantic

[REPORTS]
reports=no
score=yes